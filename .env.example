# PostgreSQL (pgvector 확장 설치 필요: CREATE EXTENSION vector;)
DATABASE_URL=postgresql://user:password@localhost:5432/knowhow_rag

# Anthropic API (LLM 답변 생성용)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# 임베딩 모델 (다국어 지원, 한국어 포함)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RAG 검색 설정
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# 카카오 챗봇에서 이 백엔드를 호출할 때 사용할 공유 시크릿(선택)
KAKAO_SKILL_SECRET=change-me

# 현장 공통 가이드/사규 문서 - Claude 프롬프트 캐싱 TTL ("5m" 무료 / "1h" 쓰기비용 2배지만 오래 유지)
GUIDE_CACHE_TTL=1h

# Dify로 만든 챗봇을 카카오톡과 연결할 때 (자체 RAG 챗봇과는 별개)
DIFY_API_BASE=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxxxxxx
